---
interface Props {
  title: string;
  description?: string;
  theme?: 'editorial' | 'brutalist' | 'swiss' | 'warm' | 'dark';
  bodyTheme?: boolean; // when true, sets data-theme on <body> (article pages)
  extraCss?: string[];
}
const {
  title,
  description = 'Samuel Obukwelu — builder, operator, engineer.',
  theme = 'editorial',
  bodyTheme = false,
  extraCss = [],
} = Astro.props;
---
<!doctype html>
<html lang="en" data-theme={bodyTheme ? undefined : theme}>
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,500;0,8..60,600;0,8..60,700;1,8..60,400;1,8..60,500&family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@400;500;600;700&display=swap"
  rel="stylesheet"
/>
<link rel="stylesheet" href="/styles.css?v=20260425b" />
{extraCss.map((href) => <link rel="stylesheet" href={href} />)}
<script is:inline>
  (function () {
    try {
      var m = localStorage.getItem('color-mode');
      if (m === 'light' || m === 'dark') {
        document.documentElement.setAttribute('data-color-mode', m);
      }
    } catch (e) {}
  })();
</script>
</head>
<body data-theme={bodyTheme ? theme : undefined}>
<slot />
</body>
</html>
