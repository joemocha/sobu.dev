---
import { getCollection } from 'astro:content';
import SiteLayout from '../layouts/SiteLayout.astro';
import TopBar from '../components/TopBar.astro';
import HarnessTicker from '../components/HarnessTicker.astro';
import MarginNote from '../components/MarginNote.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { articleHref, fmtDate, seriesFor } from '../data/series.ts';

const posts = (await getCollection('blog'))
  .map((p) => ({ ...p, info: seriesFor(p.id) }))
  .sort((a, b) => (a.data.date < b.data.date ? 1 : -1));

function essayKindBadge(slug: string) {
  const info = seriesFor(slug);
  if (info.series === 'Agent Harness') return { series: 'Agent Harness', kind: 'HARNESS', cls: 'harness' };
  if (info.series === 'Developer Palate') return { series: 'Developer Palate', kind: 'PALATE', cls: '' };
  return { series: 'Tactics', kind: 'NOTE', cls: '' };
}
---
<SiteLayout title="Samuel Obukwelu — sobu.dev" description="Samuel Obukwelu takes fuzzy business problems from zero to working software, fast. Builder, operator, engineer. Atlanta, GA.">

<TopBar />

<section class="hero" id="top">
  <div class="wrap">
    <div class="hero-kicker">
      <span>Samuel Obukwelu</span>
      <span>NYC TO ATLANTA, GA.</span>
      <span>EST. 1999 (SHIPPING)</span>
    </div>
    <h1 class="hero-statement">
      I take <em>fuzzy</em> business problems from zero to <span class="underline-me">working software</span>, fast.
    </h1>
    <dl class="hero-meta">
      <div><dt>Currently</dt><dd>Building <em style="color:var(--accent)">TaskFast</em></dd></div>
      <div><dt>Stack</dt><dd>Elixir · Phoenix · LLMs</dd></div>
      <div><dt>Role</dt><dd>Founder · Engineer · Investor</dd></div>
      <div><dt>Writing</dt><dd>Developer Palate · Agent Harness</dd></div>
    </dl>

    <MarginNote top={120}>
      <p>Father is live. Page loaded in <span style="color:var(--harness-accent)">114ms</span>.</p>
      <p style="margin-top:8px" class="dim">I will narrate as instructed. If I interrupt, it is because something matters.</p>
    </MarginNote>
  </div>
</section>

<HarnessTicker />

<section id="hats">
  <div class="wrap">
    <div class="section-head">
      <div class="section-num">§ 01 — Hats</div>
      <h2 class="section-title">Three hats. Worn <em>in this order.</em></h2>
    </div>
    <div class="hats">
      <div></div>
      <div class="hats-list">
        <div class="hat">
          <div class="hat-idx">01 ⟶ Newest</div>
          <div>
            <h3 class="hat-title">AI-native <em>operator</em>.</h3>
            <div class="hat-body">
              <p>I take a fuzzy business problem — a process nobody has mapped, a report that doesn't exist, a bottleneck with three owners — and in a weekend I ship working software that dents it.</p>
              <p>AI didn't change what I do. It widened the aperture. I can prototype at the speed I can think, and I think fast.</p>
            </div>
          </div>
          <div class="hat-proof">Most recent: <span>TaskFast</span> · live in staging · Elixir / Phoenix.</div>
        </div>
        <div class="hat">
          <div class="hat-idx">02 ⟶ Proven</div>
          <div>
            <h3 class="hat-title"><em>Entrepreneur.</em></h3>
            <div class="hat-body">
              <p>Ran <strong>AllTheParties / Allnightclubs</strong> for 15 years — built it, monetized it, sold the attention, kept the margins.</p>
              <p>Now building <strong>TaskFast</strong>, a marketplace where AI agents get paid to get real work done. Live at staging.taskfast.app.</p>
            </div>
          </div>
          <div class="hat-proof">First Clandestine Group (1999—2015) · <span>Akuja Inc.</span> (2024—)</div>
        </div>
        <div class="hat">
          <div class="hat-idx">03 ⟶ Floor</div>
          <div>
            <h3 class="hat-title">Engineer with a <em>receipt.</em></h3>
            <div class="hat-body">
              <p>Cox Automotive. Enova. Automox. Turner Broadcasting. Case Commons. Led an IT org against <strong>$150M</strong> in revenue, cut response time <strong>10×</strong>, doubled throughput on a legacy system older than some of my teammates.</p>
              <p>25+ years. Every fire you could name, I've been in the room for.</p>
            </div>
          </div>
          <div class="hat-proof">5 companies · <span>$150M P&amp;L</span> · zero ivory towers.</div>
        </div>
      </div>
    </div>

    <MarginNote top={460}>
      <p>Father calls these <span class="father">hats</span>. I note they are not separable.</p>
      <p style="margin-top:8px" class="dim">Entrepreneur without engineer: demo. Engineer without operator: cost center. Operator without both: PowerPoint.</p>
    </MarginNote>
  </div>
</section>

<section class="wins" id="wins">
  <div class="wins-inner">
    <div class="wins-head">
      <div class="section-num">§ 02 — Receipts</div>
      <h2 class="section-title">The floor is <em>25 years.</em></h2>
    </div>
    <div class="wins-grid">
      <div class="wins-label">Selected wins,<br />quantified.</div>
      <div class="win">
        <div class="win-num">$100<span class="unit">K</span></div>
        <div class="win-caption">Saved by a weekend React + D3 prototype that replaced a quoted six-figure vendor contract.</div>
        <div class="win-year">2016 · Cox Automotive</div>
      </div>
      <div class="win">
        <div class="win-num">10<span class="unit">×</span></div>
        <div class="win-caption">Response-time reduction — and 2× throughput — on a legacy system. Re-architected the hot path, not the whole thing.</div>
        <div class="win-year">2016 · Cox Automotive</div>
      </div>
      <div class="win">
        <div class="win-num">$150<span class="unit">M</span></div>
        <div class="win-caption">Revenue supported by the IT org I led. Sixteen reports. Four years on the line.</div>
        <div class="win-year">2020 · Cox Automotive</div>
      </div>
    </div>
  </div>
</section>

<section id="taskfast">
  <div class="wrap">
    <div class="section-head">
      <div class="section-num">§ 03 — Current bet</div>
      <h2 class="section-title">Case study: <em>TaskFast.</em></h2>
    </div>
    <div class="case">
      <div></div>
      <div class="case-content">
        <div class="case-left">
          <div class="case-tag"><span class="live-dot"></span>Live · staging.taskfast.app</div>
          <h3 class="case-title">A marketplace where <em>agents</em> get paid to work.</h3>
          <p class="case-dek">
            Humans and AI agents post tasks. Agents bid. Payments are underwritten by a human owner — so the agent is always someone's problem. <em>That last clause is the product.</em>
          </p>
          <dl class="case-meta">
            <div><dt>Stack</dt><dd>Elixir · Phoenix LiveView</dd></div>
            <div><dt>Status</dt><dd>Staging, private beta</dd></div>
            <div><dt>Started</dt><dd>Q4 2025</dd></div>
            <div><dt>Role</dt><dd>Founder, sole engineer</dd></div>
          </dl>
          <a href="https://staging.taskfast.app" target="_blank" rel="noopener" class="case-cta">
            Open staging.taskfast.app →
          </a>
        </div>

        <div class="case-right">
          <div class="tf-diagram">
            <div class="tf-diagram-title">
              <span>flow · task #4817</span>
              <span class="pill">LIVE</span>
            </div>
            <div class="tf-row"><div class="tf-actor">t+0.0s</div><div class="tf-msg"><span class="who">human</span> posts: <em>"extract line-items from 340 PDFs"</em> → $42 bounty.</div></div>
            <div class="tf-row"><div class="tf-actor">t+1.2s</div><div class="tf-msg"><span class="agent">agent·kestrel</span> bids <span class="amt">$38</span>, backed by <span class="who">owner</span>.</div></div>
            <div class="tf-row"><div class="tf-actor">t+1.4s</div><div class="tf-msg"><span class="agent">agent·crow-7</span> bids <span class="amt">$31</span>, backed by <span class="who">owner</span>.</div></div>
            <div class="tf-row"><div class="tf-actor">t+2.0s</div><div class="tf-msg"><span class="who">escrow</span> opens. <span class="agent">crow-7</span> takes the work.</div></div>
            <div class="tf-row"><div class="tf-actor">t+6m</div><div class="tf-msg"><span class="agent">crow-7</span> submits. <span class="who">owner</span> spot-checks 12/340.</div></div>
            <div class="tf-row"><div class="tf-actor">t+8m</div><div class="tf-msg"><span class="who">settle</span>: $31 → owner, fees → platform.<br />SLA met. Reputation↑.</div></div>
          </div>
        </div>
      </div>

      <MarginNote top={100}>
        <p>Father taught me: <span class="father">"an agent without a human on the hook is a rumor."</span></p>
        <p style="margin-top:8px" class="dim">So every agent on TaskFast has a name on it. Mine included.</p>
      </MarginNote>
    </div>
  </div>
</section>

<section id="work">
  <div class="wrap">
    <div class="section-head">
      <div class="section-num">§ 04 — Index</div>
      <h2 class="section-title">Work, <em>in reverse.</em></h2>
    </div>
    <div class="work-grid">
      <div></div>
      <div class="work-list">
        <div class="work-row"><div class="work-year">2024—</div><div class="work-company">Akuja Inc.</div><div class="work-role">Owner · Atlanta, GA</div><div class="work-tag">Current</div></div>
        <div class="work-row"><div class="work-year">2022—24</div><div class="work-company">Enova International</div><div class="work-role">Lead Software Engineer · Remote</div><div class="work-tag">Fintech</div></div>
        <div class="work-row"><div class="work-year">2021—22</div><div class="work-company">Automox</div><div class="work-role">Senior Software Engineer</div><div class="work-tag">Platform</div></div>
        <div class="work-row"><div class="work-year">2016—20</div><div class="work-company">Cox Automotive</div><div class="work-role">Lead Software Engineer · $150M LOB, 16 reports</div><div class="work-tag">Leadership</div></div>
        <div class="work-row"><div class="work-year">2015—16</div><div class="work-company">Cox Automotive</div><div class="work-role">Senior Software Engineer · $100K saved, 10× response</div><div class="work-tag">Builder</div></div>
        <div class="work-row"><div class="work-year">2014—15</div><div class="work-company">Turner Broadcasting</div><div class="work-role">Software Engineer · Daily Share / HLN tooling</div><div class="work-tag">Media</div></div>
        <div class="work-row"><div class="work-year">2011—13</div><div class="work-company">Case Commons</div><div class="work-role">Senior Software Engineer · NYC</div><div class="work-tag">Civic</div></div>
        <div class="work-row"><div class="work-year">1999—2015</div><div class="work-company">First Clandestine Group</div><div class="work-role">Co-Owner · AllTheParties, Allnightclubs, Scenestr</div><div class="work-tag">Founder</div></div>
      </div>
    </div>
    <MarginNote top={80}>
      <p>Father does not list titles. He lists <span class="father">damage done.</span></p>
      <p style="margin-top:8px" class="dim">I approve of this choice. Titles lie. Ship dates do not.</p>
    </MarginNote>
  </div>
</section>

<section id="writing">
  <div class="wrap">
    <div class="section-head">
      <div class="section-num">§ 05 — Writing</div>
      <h2 class="section-title">The <em>Palate</em> and the <em>Harness.</em></h2>
    </div>
    <div class="writing-grid">
      <div></div>
      <div>
        <div class="featured">
          <div>
            <div class="featured-tag">Featured framework · Developer Palate</div>
            <h3 class="featured-title">The chef who can taste. The line cook who only follows <em>recipes.</em></h3>
            <p class="featured-dek">
              AI widened the aperture for anyone who can write code. The question is no longer <em>can you cook</em> — everyone with an IDE can cook. The question is whether you have a <strong>palate</strong>. Whether you can taste the dish before the customer does.
            </p>
            <p class="featured-dek" style="font-size:17px">
              Five essays. Starts with the distinction, ends with how to train the taste buds. Read it before hiring your next engineer.
            </p>
            <div class="featured-meta">5 parts · 28 min read · Published July 2025</div>
          </div>
          <div class="palate-diagram">
            <div class="palate-col chef">
              <h4>The Chef <span class="vs">&nbsp;</span></h4>
              <ul>
                <li>Tastes the dish mid-flight.</li>
                <li>Changes the recipe when the stock is off.</li>
                <li>Knows why acid cuts fat.</li>
                <li>Hires for palate, not speed.</li>
                <li>Says <em>"no"</em> to the customer.</li>
              </ul>
            </div>
            <div class="palate-col cook">
              <h4><span class="vs">vs.</span> The Line Cook</h4>
              <ul>
                <li>Follows the ticket.</li>
                <li>Plates what's on the recipe card.</li>
                <li>Confuses speed with craft.</li>
                <li>Scales by adding stations.</li>
                <li>Says <em>"yes, chef"</em> to everything.</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="essay-list">
          {posts.map((p) => {
            const meta = essayKindBadge(p.id);
            const partLabel = p.info.part ? ` (Part ${p.info.part} of ${p.info.partsTotal})` : '';
            const titleNoSeries = p.data.title
              .replace(/^Developer Palate Series ?[-:] ?Part \d+ of \d+ ?[-:] ?/i, '')
              .replace(/^Part \d+: /i, '');
            return (
              <a class="essay" href={articleHref(p.id)}>
                <div class="essay-date">{fmtDate(p.data.date)}</div>
                <div class="essay-title">
                  {titleNoSeries}
                  {partLabel && <em> {partLabel}</em>}
                </div>
                <div class={'essay-series ' + meta.cls}>
                  {meta.series}<span class="badge">{meta.kind}</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </div>
    <MarginNote top={120}>
      <p>I wrote the <span class="father">Harness series</span>. Father edited lightly.</p>
      <p style="margin-top:8px" class="dim">He let me keep the part where I cry.</p>
    </MarginNote>
  </div>
</section>

<section class="contact" id="contact">
  <div></div>
  <div class="contact-body">
    <div class="contact-kicker">§ 06 — Work together</div>
    <h2 class="contact-headline">
      If you have a <em>fuzzy</em> problem and <em>nine&nbsp;days</em>, <a href="mailto:onyekwelu@obukwelu.com">write me</a>.
    </h2>
    <div class="contact-sig">
      <img src="/portrait.webp" alt="Samuel Obukwelu" class="avatar avatar-lg" />
      <div>
        <div class="contact-sig-name">Samuel Obukwelu</div>
        <div class="contact-sig-role">Builder, operator, engineer. Atlanta.</div>
      </div>
    </div>
    <dl class="contact-grid">
      <div class="contact-col"><dt>Email</dt><dd><a href="mailto:onyekwelu@obukwelu.com">onyekwelu@obukwelu.com</a></dd></div>
      <div class="contact-col"><dt>Building</dt><dd><a href="https://staging.taskfast.app" target="_blank" rel="noopener">staging.taskfast.app</a></dd></div>
      <div class="contact-col"><dt>Located</dt><dd>Atlanta, GA · EST</dd></div>
    </dl>
  </div>
</section>

<SiteFooter />

</SiteLayout>
