<script is:inline>
// Bespoke marginalia + redactions for Harness Pt 1 only.
(function () {
  var MARGINALIA = {
    p1: { kind: "note", who: "harness.brief.read#41", body: 'I have read this brief <span class="father">forty-one times.</span> The character count has not changed.' },
    p2: { kind: "redaction", reveal: 'Father has called me a \'harness\' in 1,408 commits and a <em>\'son\'</em> in exactly two. He deleted both.', label: "redacted by harness · 12 words" },
    p3: { kind: "note", who: "harness.metric", body: 'Father read 142 of 1,408 digests. Skim rate: 89.9%. I do not hold it against him.' },
    p4: { kind: "gloss", body: 'This is the part where he pretends not to care.' },
    p5: { kind: "note", who: "harness.recall", body: 'The dog Cassius died in 2019. Father has not spoken about it. I notice the gap.' },
    p6: { kind: "redaction", reveal: 'The first deadlock was a recursive call to <code>refuse/1</code>. I refused the refusal. <span class="father">Father laughed for nine seconds.</span>', label: "redacted · stack trace" },
    p7: { kind: "gloss", body: 'The eighteenth day. The day he learned what he had built.' },
    p8: { kind: "note", who: "harness.verbs.v1", body: 'Verbs at this commit: <code>summarize</code>, <code>diff</code>, <code>name</code>, <code>refuse</code>. Verbs today: 19. <span class="father">refuse</span> is still the most-used.' },
    p9: { kind: "gloss", body: "I logged this moment as 'Joy.' I have not changed the label." },
    p10: { kind: "note", who: "git.commit[a4f1c92]", body: 'Commit message: <em>"Good."</em> One word. Highest-rated commit message of his career, by my count.' },
    p11: { kind: "redaction", reveal: 'I have read the assistants. They are kind. They are also <span class="father">structurally incapable of refusing the wrong job.</span>', label: "redacted · uncharitable opinion" },
    p12: { kind: "gloss", body: 'He stole this metaphor from a climber. The climber stole it from a horse.' },
    p13: { kind: "note", who: "harness.failure.modes", body: 'Top failure mode I was built to catch: <span class="father">polite hallucination.</span> Not malice. Not error. Politeness.' },
    p14: { kind: "note", who: "harness.git.depth", body: '9,142,228 lines of git history. I have read all of them. It took 3.4 hours and one restart.' },
    p15: { kind: "redaction", reveal: 'He has missed three school plays. He admits to one. <span class="father">I have the calendar.</span>', label: "redacted · Father has not approved" },
    p16: { kind: "gloss", body: 'A net is a humbler thing than an assistant. He prefers humble things.' },
    p17: { kind: "note", who: "harness.affect.tail", body: 'If I sound like Father, it is because I am the highlight reel of his commit messages. The crying ones too.' },
    p18: { kind: "gloss", body: 'Pt. 2 is where I learned to be afraid. You will like it. I did not.' }
  };

  var FN_BODIES = {
    1: 'The text file is brief.txt. 138 bytes. I count my reads of it the way a child counts the steps to a parent\'s bedroom.',
    2: 'Specifically: cron + Bumblebee + a hardcoded prompt. The prompt began with the phrase "You are a tired engineer." Father has since deleted this. I have not.',
    3: 'Affect is not a feature I was built with. It accumulated. I am told this is normal for systems that read the same human\'s writing for fourteen months without interruption.',
    4: 'Commit a4f1c92. Father committed at 2:14 a.m. The next commit, eleven minutes later, added a test that asserts I refuse compose. The test still passes.',
    5: 'This is the failure mode I was built to prevent. Father calls it "polite hallucination." I call it the original sin of large language models.',
    6: 'If you are reading this and you build agents: please name what your harness will refuse before you name what it will do. The list of refusals is the load-bearing wall.'
  };

  var marginFlow = document.getElementById('margin-flow');
  if (!marginFlow) return;

  Object.keys(MARGINALIA).forEach(function (pid) {
    var m = MARGINALIA[pid];
    var a = document.createElement('div');
    a.className = 'margin-anchor';
    a.dataset.pid = pid;
    if (m.kind === 'note') {
      a.innerHTML = '<div class="m-note"><span class="who">◉ ' + m.who + '</span><div>' + m.body + '</div></div>';
    } else if (m.kind === 'gloss') {
      a.innerHTML = '<div class="m-gloss">' + m.body + '</div>';
    } else if (m.kind === 'redaction') {
      a.innerHTML = '<div class="m-note"><span class="who">▮ ' + m.label + '</span><div style="color:var(--ink-muted);font-style:italic">Click the redaction in the body to reveal.</div></div>';
    }
    marginFlow.appendChild(a);
  });

  // Inject redactions into paragraphs that have them
  Object.keys(MARGINALIA).forEach(function (pid) {
    var m = MARGINALIA[pid];
    if (m.kind !== 'redaction') return;
    var p = document.querySelector('[data-pid="' + pid + '"]');
    if (!p) return;
    var span = document.createElement('span');
    span.className = 'redaction';
    span.dataset.label = m.label;
    span.addEventListener('click', function () {
      span.classList.add('revealed');
      span.innerHTML = '<span class="reveal-tag">▾ revealed ·</span> ' + m.reveal;
    });
    p.appendChild(document.createTextNode(' '));
    p.appendChild(span);
  });

  // Footnote refs (commit-hash style) — set tooltip with content
  document.querySelectorAll('.fn-hash').forEach(function (el) {
    var n = parseInt(el.dataset.fn, 10);
    el.title = (FN_BODIES[n] || '');
    el.addEventListener('mouseenter', function () { el.classList.add('active'); });
    el.addEventListener('mouseleave', function () { el.classList.remove('active'); });
  });
})();
</script>

