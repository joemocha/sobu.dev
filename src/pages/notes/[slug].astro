---
import { getCollection, render } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';
import TopBar from '../../components/TopBar.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { fmtDate } from '../../data/series.ts';
import { KIND_LABELS, hostnameOf } from '../../data/notes.ts';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((n) => ({ params: { slug: n.id }, props: { note: n } }));
}

const { note } = Astro.props;
const { Content } = await render(note);
const d = note.data;

const titleForHead =
  d.kind === 'til' ? d.title :
  d.kind === 'quote' ? `"${d.quote.slice(0, 60)}${d.quote.length > 60 ? '…' : ''}" — ${d.source}` :
  d.kind === 'link' ? (d.title ?? hostnameOf(d.original)) :
  d.kind === 'aside' ? (d.title ?? `Note · ${fmtDate(d.date)}`) :
  `Note · ${fmtDate(d.date)}`;

const dekForHead =
  d.kind === 'status' ? `Status update · ${fmtDate(d.date)}` :
  d.kind === 'link' ? `Linkblog · ${hostnameOf(d.original)}` :
  d.kind === 'quote' ? `Quote · ${d.source}` :
  d.kind === 'til' ? `Today I learned · ${fmtDate(d.date)}` :
  `Aside · ${fmtDate(d.date)}`;
---
<SiteLayout title={`${titleForHead} — sobu.dev`} description={dekForHead}>

<TopBar />

<article class="note-page" id="top">
  <div class="wrap">
    <div class="note-meta">
      <a href="/notes.html" class="note-back">← Notes</a>
      <span class="note-meta-sep">·</span>
      <time class="note-date">{fmtDate(d.date)}</time>
      <span class="note-meta-sep">·</span>
      <span class={`note-kind kind-${d.kind}`}>{KIND_LABELS[d.kind]}</span>
    </div>

    {d.kind === 'til' && (
      <h1 class="note-title">{d.title}</h1>
    )}

    {d.kind === 'aside' && d.title && (
      <h1 class="note-title">{d.title}</h1>
    )}

    {d.kind === 'link' && (
      <div class="note-link-head">
        <div class="note-link-source">{hostnameOf(d.original)}</div>
        {d.title && <h1 class="note-title">{d.title}</h1>}
        <a href={d.original} target="_blank" rel="noopener" class="note-link-original">
          ↗ {d.original}
        </a>
      </div>
    )}

    {d.kind === 'quote' && (
      <blockquote class="note-quote">
        <p>{d.quote}</p>
        <footer class="note-quote-attr">
          —{' '}
          {d.source_url ? (
            <a href={d.source_url} target="_blank" rel="noopener">{d.source}</a>
          ) : (
            <span>{d.source}</span>
          )}
        </footer>
      </blockquote>
    )}

    <div class="note-body prose">
      <Content />
    </div>

    {d.tags && d.tags.length > 0 && (
      <div class="note-tags">
        {d.tags.map((t) => <span class="note-tag">#{t}</span>)}
      </div>
    )}

    <div class="note-foot">
      <a href="/notes.html" class="note-back">← Back to notes</a>
    </div>
  </div>
</article>

<SiteFooter />

</SiteLayout>
